extends: default

rules:
  line-length: disable
  indentation:
    spaces: 2
    indent-sequences: true
  document-start: disable
  truthy: disable
  new-line-at-end-of-file: disable
  trailing-spaces: disable # Desactivado para evitar errores de espacios invisibles
  comments: disable # Desactivado para evitar errores de formato en comentarios
